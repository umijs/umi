{
  "$schema": "./node_modules/@utoo/lint/schema.json",
  "files": [
    "packages/ast/src",
    "packages/babel-preset-umi/src",
    "packages/bundler-esbuild/src",
    "packages/bundler-utils/src",
    "packages/bundler-utoopack/src",
    "packages/bundler-vite/src",
    "packages/bundler-webpack/src",
    "packages/core/src",
    "packages/create-umi/src",
    "packages/lint/src",
    "packages/max/src",
    "packages/mfsu/src",
    "packages/plugin-docs/src",
    "packages/plugin-run/src",
    "packages/plugins/src",
    "packages/preset-umi/src",
    "packages/preset-vue/src",
    "packages/renderer-react/src",
    "packages/renderer-vue/src",
    "packages/server/src",
    "packages/testing/src",
    "packages/umi/src",
    "packages/utils/src",
    "packages/zod2ts/src",
    "codemod/src",
    "scripts",
    "libs/valtio/src"
  ],
  "ignores": [
    "**/compiled/**",
    "**/fixtures/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/.umi/**",
    "**/.umi-production/**",
    "**/.umi-test/**",
    "**/.mfsu/**"
  ],
  "rules": {
    "no-debugger": "error",
    "no-alert": "error",
    "no-console": "warn",
    "no-unused-vars": "warn",
    "prefer-const": "warn",
    "eqeqeq": "error",
    "use-isnan": "error",
    "valid-typeof": "error",
    "no-constant-condition": "error",
    "no-dupe-keys": "error",
    "no-duplicate-imports": "error",
    "import/first": "error",
    "import/newline-after-import": "warn",
    "import/no-duplicates": "error",
    "import/no-self-import": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/jsx-no-target-blank": "error",
    "react/jsx-pascal-case": "warn",
    "react/no-danger": "warn",
    "react/no-find-dom-node": "error",
    "react/no-unescaped-entities": "error",
    "jsx-a11y/aria-props": "error",
    "jsx-a11y/aria-unsupported-elements": "error",
    "jsx-a11y/iframe-has-title": "error",
    "jsx-a11y/img-redundant-alt": "warn",
    "jsx-a11y/no-access-key": "error",
    "@typescript-eslint/no-unused-vars": "error",
    "@typescript-eslint/no-use-before-define": "error",
    "@typescript-eslint/no-shadow": "error",
    "@typescript-eslint/no-redeclare": "error",
    "@typescript-eslint/consistent-type-assertions": "warn",
    "@typescript-eslint/consistent-type-definitions": "warn",
    "@typescript-eslint/no-empty-interface": "warn",
    "@typescript-eslint/no-non-null-asserted-optional-chain": "error"
  }
}
